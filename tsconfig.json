{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "jsx": "react-jsx",
    "paths": {
      "@shared": ["./src/shared/index.ts"],
      "@shared/*": ["./src/shared/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "electron/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "electron-vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "out", "release", "packages"]
}
