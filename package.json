{
  "name": "dndmate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "bun --filter @dndmate/server dev",
    "dev:web": "bun --filter @dndmate/web dev",
    "build": "bun --filter @dndmate/web build",
    "start": "bun --filter @dndmate/server start",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
